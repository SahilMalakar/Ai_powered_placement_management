{
    "name": "backend_ai_powered_placement_management",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "scripts": {
        "build": "tsc -b",
        "postbuild": "node scripts/copy-templates.js",
        "start": "node dist/index.js",
        "dev": "pnpm run build && pnpm run start",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:generate": "cd src && pnpm dlx prisma generate",
        "cache:clear": "node scripts/check-queue.js --clear-cache",
        "cache:list": "node scripts/check-queue.js --list-cache",
        "db:start": "docker compose -f docker/docker-compose.dev.yml up -d",
        "db:stop": "docker compose -f docker/docker-compose.dev.yml down",
        "db:logs": "docker compose -f docker/docker-compose.dev.yml logs -f",
        "test:db:up": "docker compose -f docker/docker-compose.test.yml up -d",
        "test:db:down": "docker compose -f docker/docker-compose.test.yml down",
        "test:db:migrate": "dotenv -e .env.test -- prisma migrate deploy --schema=src/prisma/schema.prisma",
        "test": "dotenv -e .env.test -- vitest run",
        "test:watch": "dotenv -e .env.test -- vitest"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.32.1",
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@langchain/core": "^1.1.49",
        "@langchain/google-genai": "^2.1.27",
        "@langchain/groq": "^1.2.0",
        "@langchain/langgraph": "^1.4.2",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@react-pdf/renderer": "^4.5.1",
        "autocannon": "^8.0.0",
        "axios": "^1.17.0",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.71.1",
        "cloudinary": "^2.9.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "fast-csv": "^5.0.7",
        "handlebars": "^4.7.9",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.3",
        "langchain": "^1.2.37",
        "mammoth": "^1.12.0",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.4",
        "pdf-parse": "^2.4.5",
        "pg": "^8.20.0",
        "react": "^19.2.5",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.5.0",
        "@types/nodemailer": "^7.0.11",
        "@types/pdf-parse": "^1.1.5",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.14",
        "@types/supertest": "^7.2.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "dotenv-cli": "^11.0.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.2",
        "prisma": "^7.5.0",
        "supertest": "^7.2.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "vitest": "^4.1.8"
    }
}