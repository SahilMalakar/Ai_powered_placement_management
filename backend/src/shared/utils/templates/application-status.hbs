<html>
    <head>
        <style>
            body {
                font-family: 'Segoe UI', Arial, sans-serif;
                color: #333;
                line-height: 1.6;
                margin: 0;
                padding: 20px;
                background-color: #f4f7f6;
            }
            .container {
                max-width: 600px;
                margin: 0 auto;
                background: #ffffff;
                padding: 0;
                border: 1px solid #e2e8f0;
                border-radius: 8px;
                overflow: hidden;
            }
            .header {
                background-color: #818cf8;
                color: white;
                padding: 20px;
                text-align: center;
            }
            .header h2 {
                margin: 0;
            }
            .content {
                padding: 30px;
            }
            .status-box {
                background-color: #f0fdf4;
                padding: 20px;
                border-left: 4px solid #1D9E75;
                margin: 20px 0;
                border-radius: 0 8px 8px 0;
            }
            .status-label {
                display: inline-block;
                background-color: #1D9E75;
                color: white;
                padding: 4px 12px;
                border-radius: 4px;
                font-weight: bold;
                font-size: 14px;
            }
            .btn {
                display: inline-block;
                background: linear-gradient(135deg, #818cf8, #c084fc);
                color: white;
                text-decoration: none;
                padding: 12px 24px;
                border-radius: 6px;
                font-weight: bold;
                margin-top: 20px;
                text-align: center;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            }
            .footer {
                font-size: 13px;
                color: #64748b;
                text-align: center;
                margin-top: 30px;
                padding-top: 20px;
                border-top: 1px solid #e2e8f0;
            }
        </style>
    </head>
    <body>
        <div class='container'>
            <div class='header'>
                <h2>Application Status Update</h2>
            </div>
            <div class='content'>
                <p>Hi <strong>{{studentName}}</strong>,</p>
                <p>We have an update regarding your application:</p>

                <div class='status-box'>
                    <p style='margin-top: 0;'><strong>Company:</strong>
                        {{companyName}}</p>
                    <p><strong>Role:</strong> {{jobTitle}}</p>
                    <p><strong>Status:</strong>
                        <span class='status-label'>{{status}}</span></p>
                    <p style='margin-bottom: 0; color: #475569;'>{{statusMessage}}</p>
                </div>

                <p>Log in to your dashboard for more details and next steps.</p>

                <div style='text-align: center;'>
                    <a href='{{dashboardLink}}' class='btn'>View Dashboard</a>
                </div>

                <div class='footer'>
                    <p>This is an automated message from the Placement Portal.</p>
                </div>
            </div>
        </div>
    </body>
</html>
